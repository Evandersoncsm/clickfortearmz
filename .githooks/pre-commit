#!/bin/sh

if command -v pwsh >/dev/null 2>&1; then
    exec pwsh -NoProfile -File scripts/check-staged-secrets.ps1
fi

if command -v powershell.exe >/dev/null 2>&1; then
    exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/check-staged-secrets.ps1
fi

echo "PowerShell nao encontrado; execute a verificacao de segredos manualmente." >&2
exit 1
